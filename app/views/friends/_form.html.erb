<%= form_with(model: friend) do |form| %>
  <% if friend.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(friend.errors.count, "error") %> prohibited this friend from being saved:</h2>

      <ul>
        <% friend.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <label for="first_name_input" class="form-label"><%= form.label :first_name, style: "display: block" %></label>
    <%= form.text_field :first_name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <label for="last_name_input" class="form-label"><%= form.label :last_name, style: "display: block" %></label>
    <%= form.text_field :last_name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <label for="email_input" class="form-label"><%= form.label :email, style: "display: block" %></label>
    <%= form.text_field :last_name, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <label for="phone_input" class="form-label"><%= form.label :phone, style: "display: block" %></label>
    <%= form.text_field :phone, class: 'form-control' %>
  </div>

  <%= form.submit class: 'btn btn-success' %>
<% end %>
